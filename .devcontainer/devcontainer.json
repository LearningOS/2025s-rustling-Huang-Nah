{
  "name": "Rust Dev with Docker",
  "dockerComposeFile": "dockerfile/Ubuntu_22/docker-compose.yml",
  "service": "rust-dev",
  "workspaceFolder": "/usr/src/app",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "rust-lang.rust-analyzer",
        "vadimcn.vscode-lldb"
      ]
    }
  },
  "postCreateCommand": "cargo build"
}
